# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=data_aggregation
POSTGRES_USER=dauser
POSTGRES_PASSWORD=dapassword

# ── External APIs ─────────────────────────────────────────────────────────

# Flipkart Affiliate API (free — https://affiliate.flipkart.com → sign up → API Access)
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# Amazon Associates (free — https://affiliate-program.amazon.in → sign up → get tracking ID)
# Your tracking ID looks like: yourname-21
AMAZON_AFFILIATE_TAG=

# Reddit (free — create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# YouTube Data API v3 (free — https://console.cloud.google.com)
YOUTUBE_API_KEY=

# Google Custom Search (free — 100 queries/day)
# Key: https://console.cloud.google.com → APIs → Custom Search API → Enable → Credentials
# CX:  https://programmablesearchengine.google.com → create engine → copy Search Engine ID
# Tip: you can reuse the same Google Cloud project and API key as YouTube above
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Twitter/X Basic ($100/mo — https://developer.twitter.com)
TWITTER_BEARER_TOKEN=

# Instagram Graph API (free — https://developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=

# TikTok Research API (free — https://developers.tiktok.com/products/research-api)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest API (free — https://developers.pinterest.com)
PINTEREST_ACCESS_TOKEN=
